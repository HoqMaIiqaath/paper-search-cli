{
  "name": "paper-search-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex MCP server and research skill powered by paper-search-cli.",
  "bin": {
    "paper-search-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "skills",
    ".codex-plugin",
    ".mcp.json",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "prepare": "npm run build",
    "start": "node dist/stdio.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "paper-search-cli": "0.3.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "axios": "1.18.1",
    "form-data": "4.0.6",
    "undici": "7.28.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoqMaIiqaath/paper-search-cli.git"
  },
  "homepage": "https://github.com/HoqMaIiqaath/paper-search-cli",
  "license": "MIT"
}
